# Example environment variables for FarmorOps
# Copy this to .env and fill in real values. Do NOT commit .env.

RCON_HOST=127.0.0.1
RCON_PORT=27015
# RCON_PASSWORD should be kept secret and not checked into source control
RCON_PASSWORD=your_password_here

# CS API integration settings.
CS_SERVER_API_BASE_URL=https://mkbi.chickenkiller.com:27999
CS_SERVER_API_KEY=dev-secret-change-me

# DRY_RUN=true (default) will only return previews. Set to false to execute commands.
DRY_RUN=true
